        "modeline_aliases": [
          "gitrebase"
        ]
      },
      "hidden": false,
      "grammar": "git_rebase"
    },
    "HTML": {
      "extension": "html",
      "path": "languages/html",
      "matcher": {
        "path_suffixes": [
          "html",
          "htm",
          "shtml"
