    },
    "Material Icon Theme": {
      "extension": "material-icon-theme",
      "path": "icon_themes/material-icon-theme.json"
    }
  },
  "languages": {
    "Git Attributes": {
      "extension": "git-firefly",
      "path": "languages/gitattributes",
      "matcher": {
        "path_suffixes": [
          "gitattributes",
          ".gitattributes"
        ],
        "first_line_pattern": null,
        "modeline_aliases": [
          "gitattributes"
        ]
      },
      "hidden": false,
      "grammar": "gitattributes"
    },
    "Git Config": {
      "extension": "git-firefly",
      "path": "languages/gitconfig",
      "matcher": {
        "path_suffixes": [
          "config.worktree",
          ".gitconfig",
          ".gitmodules",
          ".lfsconfig"
        ],
        "first_line_pattern": null,
        "modeline_aliases": [
          "gitconfig"
        ]
      },
      "hidden": false,
      "grammar": "git_config"
    },
    "Git Ignore": {
      "extension": "git-firefly",
      "path": "languages/gitignore",
      "matcher": {
        "path_suffixes": [
          ".containerignore",
          ".cursorignore",
          ".dockerignore",
          ".eslintignore",
          ".fdignore",
          ".gitignore",
          ".gitignore_global",
          ".git-blame-ignore-revs",
          ".ignore",
          ".npmignore",
          ".prettierignore",
          ".rgignore",
          ".vscodeignore"
        ],
        "first_line_pattern": null,
        "modeline_aliases": [
          "gitignore"
        ]
      },
      "hidden": false,
      "grammar": "gitignore"
    },
    "Git Rebase": {
      "extension": "git-firefly",
      "path": "languages/gitrebase",
      "matcher": {
        "path_suffixes": [
          "git-rebase-todo"
